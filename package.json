{
  "name": "algorycode-rent-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "local_prod": "next dev --webpack",
    "dev:local": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:contract:mock",
    "test:unit": "vitest run --coverage",
    "test:component": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:mock": "playwright test --grep @mock",
    "test:e2e:staging": "playwright test --grep @staging",
    "test:contract:mock": "vitest run src/test/contracts/rent-api.mock-contract.test.ts",
    "test:contract:staging": "vitest run src/test/contracts/rent-api.staging-contract.test.ts",
    "test:ci": "npm run lint && npm run test:unit && npm run test:contract:mock && npm run test:e2e:mock",
    "db:migrate": "psql \"$POSTGRES_URL_NON_POOLING\" -f supabase/migrations/20260518120000_initial_rent_schema.sql",
    "db:seed": "psql \"$POSTGRES_URL_NON_POOLING\" -f supabase/seed.sql",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:prisma:pull": "bash -c 'set -a && [ -f .env.local ] && . ./.env.local; set +a && prisma db pull --schemas public,auth --url \"$DIRECT_URL\"'",
    "db:prisma:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.96.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.1.0",
    "msw": "^2.14.2",
    "prisma": "^7.8.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
