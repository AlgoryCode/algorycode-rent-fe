# Supabase (varsayılan veri + auth kaynağı)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma ORM
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Eski Algory gateway/auth’e dönmek için:
# NEXT_PUBLIC_USE_RENT_GATEWAY=true
# NEXT_PUBLIC_USE_ALGORY_AUTH=true

# Seed giriş (npm run db:seed sonrası):
#   admin@algoryrent.test / AlgoryRent2026!  (RENT_ADMIN)
#   operator@algoryrent.test / AlgoryRent2026!  (RENT_MANAGER)

# Opsiyonel
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_RENT_GATEWAY_URL=
NEXT_PUBLIC_GREEN_INSURANCE_FEE=50
