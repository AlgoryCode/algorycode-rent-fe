# İstemci: aynı origin üzerinden BFF (`src/app/api/rent/[...path]`). Tarayıcı CORS/TLS sorunlarını
# sunucu tarafı proxy ile aşar.
NEXT_PUBLIC_RENT_API_BASE=/api/rent

# Sunucu (Next.js runtime): gerçek Rent API. Hosting’de (Vercel Environment Variables vb.) mutlaka ekleyin;
# NEXT_PUBLIC_ öneki kullanmayın (istemciye sızmaz).
RENT_API_UPSTREAM=https://rent-api.algorycode.com
