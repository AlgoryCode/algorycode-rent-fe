# İstemci: aynı origin üzerinden BFF (`src/app/api/rent/[...path]`). Tarayıcı CORS/TLS sorunlarını
# sunucu tarafı proxy ile aşar.
NEXT_PUBLIC_RENT_API_BASE=/api/rent

# İsteğe bağlı: proxy’nin gideceği gerçek API kökü. Boş bırakılırsa kod https://rent.algorycode.com kullanır.
# RENT_API_UPSTREAM=https://rent.algorycode.com
