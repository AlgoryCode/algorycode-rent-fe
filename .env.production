# Panelin kanonik kök URL’si (WhatsApp/mail tam link yedekleri için). Boş = çoğu akışta yalnızca
# tarayıcıdaki `window.location.origin` kullanılır; alan adı değişince burayı güncelleyin.
# NEXT_PUBLIC_APP_ORIGIN=https://panel.ornek.com

# İstemci kökü: `/api/rent` = yalnızca Next.js içindeki BFF yolu (Java rent’te `/api` yok; BFF upstream’e `/vehicles` vb. yollar).
NEXT_PUBLIC_RENT_API_BASE=/api/rent

# BFF sunucudan gerçek rent kökü (sonda / yok); gateway kullanıyorsan `/rent` dahil olmalı.
RENT_API_UPSTREAM=https://gateway.algorycode.com/rent
# Eureka sorunu varsa doğrudan public rent: https://rental.algorycode.com
